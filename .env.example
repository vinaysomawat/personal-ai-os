# Supabase (PostgreSQL + auth + RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # used by the AI Gateway, cron jobs, Telegram webhook
SUPABASE_USER_ID=               # single-user app; fallback identity for the AI Gateway when no session exists

# AI Gateway (src/lib/ai-gateway.ts)
ANTHROPIC_API_KEY=
AI_DAILY_BUDGET_USD=            # optional, default 3 — daily spend ceiling
AI_MONTHLY_BUDGET_USD=          # optional, default 50 — monthly spend ceiling
GROQ_API_KEY=                   # Telegram voice-note transcription (whisper-large-v3-turbo)

# Cron jobs (src/app/api/cron/*)
CRON_SECRET=                    # must match the Authorization: Bearer header Vercel Cron sends

# Telegram bots — one bot/token per module
TELEGRAM_BOT_TOKEN_CAREER=
TELEGRAM_BOT_TOKEN_CODING=
TELEGRAM_BOT_TOKEN_DOCUMENTS=
TELEGRAM_BOT_TOKEN_FINANCE=
TELEGRAM_BOT_TOKEN_HEALTH=
TELEGRAM_BOT_TOKEN_LEARNING=
TELEGRAM_BOT_TOKEN_PLANNER=
TELEGRAM_ALLOWED_CHAT_ID=       # only this chat ID may talk to the bots
TELEGRAM_DAILY_AI_CAP=          # optional, default 300 — max AI-backed Telegram calls/day
